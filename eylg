                    <!-- Google Maps iframe プレースホルダー -->
                    <div class="w-full h-full flex items-center justify-center text-gray-500 text-sm">
                        [Google Map Area]
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- お問い合わせ・予約 -->
    <section id="contact" class="py-16 md:py-24 bg-darker border-t border-gray-800">
        <div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8">
            <div class="text-center mb-10 md:mb-16">
                <h2 class="text-2xl md:text-3xl font-bold text-white mb-4 tracking-widest">CONTACT & RESERVATION</h2>
                <div class="w-12 h-1 bg-primary mx-auto mb-6"></div>
                <p class="text-gray-400 text-sm leading-relaxed">
                    まずは無料カウンセリングにて、現在のお悩みや目標をお聞かせください。<br class="hidden sm:block">
                    無理な勧誘は一切行っておりませんのでご安心ください。
                </p>
            </div>

            <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12">
                <!-- LINE CTA -->
                <div class="bg-panel border border-gray-800 p-6 sm:p-8 flex flex-col items-center justify-center text-center rounded-sm">
                    <h3 class="text-lg sm:text-xl md:text-2xl font-bold text-white mb-4">LINEで簡単予約・ご相談</h3>
                    <p class="text-gray-300 text-xs sm:text-sm leading-relaxed mb-8">
                        友だち追加後、すぐにメッセージでご質問や<br class="hidden sm:block">無料カウンセリングの予約が可能です。<br>
                    </p>
                    <a href="#" class="w-full max-w-sm bg-line text-white font-bold py-4 text-sm sm:text-base tracking-wider hover:bg-green-600 transition-colors flex items-center justify-center rounded-sm shadow-lg shadow-green-900/20">
                        <svg class="w-5 h-5 sm:w-6 sm:h-6 mr-2" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M24 10.304c0-5.369-5.383-9.738-12-9.738-6.616 0-12 4.369-12 9.738 0 4.814 4.269 8.846 10.036 9.608.391.084.922.258 1.057.592.122.303.079.759.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.304z"/>
                        </svg>
                        LINEで友だち追加する
                    </a>
                </div>

                <!-- 問い合わせフォーム -->
                <div class="bg-panel border border-gray-800 p-6 sm:p-8 rounded-sm">
                    <h3 class="text-lg sm:text-xl font-bold text-white mb-6 text-center border-b border-gray-700 pb-4">メールでのご予約・お問い合わせ</h3>
                    <form class="space-y-5">
                        <div>
                            <label for="name" class="block text-xs sm:text-sm font-medium text-gray-300 mb-2">お名前 <span class="text-primary text-xs ml-1">必須</span></label>
                            <input type="text" id="name" required class="w-full bg-darker border border-gray-700 rounded-sm px-4 py-3 text-white text-sm focus:outline-none focus:border-primary" placeholder="山田 太郎">
                        </div>
                        <div>
                            <label for="email" class="block text-xs sm:text-sm font-medium text-gray-300 mb-2">メールアドレス <span class="text-primary text-xs ml-1">必須</span></label>
                            <input type="email" id="email" required class="w-full bg-darker border border-gray-700 rounded-sm px-4 py-3 text-white text-sm focus:outline-none focus:border-primary" placeholder="example@domain.com">
                        </div>
                        <div>
                            <label for="phone" class="block text-xs sm:text-sm font-medium text-gray-300 mb-2">電話番号</label>
                            <input type="tel" id="phone" class="w-full bg-darker border border-gray-700 rounded-sm px-4 py-3 text-white text-sm focus:outline-none focus:border-primary" placeholder="090-0000-0000">
                        </div>
                        <div>
                            <label for="message" class="block text-xs sm:text-sm font-medium text-gray-300 mb-2">ご要望・ご質問</label>
                            <textarea id="message" rows="4" class="w-full bg-darker border border-gray-700 rounded-sm px-4 py-3 text-white text-sm focus:outline-none focus:border-primary" placeholder="無料カウンセリング希望日時（第3希望まで）などをご記入ください。"></textarea>
                        </div>
                        <div class="pt-2">
                            <button type="submit" class="w-full bg-primary text-black font-bold py-4 text-sm sm:text-base tracking-wider hover:bg-yellow-600 transition-colors rounded-sm">
                                入力内容を送信する
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </section>

    <!-- フッター -->
    <footer class="bg-black py-8 border-t border-gray-900 text-center">
        <div class="mb-4">
            <a href="#" class="text-xl font-bold tracking-widest text-white">EY<span class="text-primary">LG</span></a>
        </div>
        <p class="text-gray-600 text-xs tracking-wider">
